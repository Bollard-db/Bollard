# ── Bollard MCP Server Settings ────────────────────────────────────────────
# Copy this file to .env and fill in values as needed.
# All settings have sane defaults — only override what you need.

# Server display name (shown in Cursor/VS Code MCP panel)
# BOLLARD_SERVER_NAME=Bollard Database MCP

# Query Safety Defaults
# BOLLARD_DEFAULT_MAX_ROWS=1000         # Auto-LIMIT for SELECT queries
# BOLLARD_DEFAULT_QUERY_TIMEOUT=30      # Seconds before query is cancelled
# BOLLARD_DEFAULT_MAX_COST=100000       # Max estimated PostgreSQL planner cost

# State Persistence
# BOLLARD_SESSION_HISTORY_LIMIT=100     # Max queries kept in history per connection
# BOLLARD_SCHEMA_CACHE_TTL=300          # Schema cache TTL in seconds (5 min)

# Credential Storage
# BOLLARD_CREDENTIAL_BACKEND=auto       # 'auto' | 'keyring' | 'encrypted'
# BOLLARD_ENCRYPTION_KEY=               # Base64 Fernet key (only for 'encrypted' backend)
#   Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# Debug Mode
# BOLLARD_DEBUG=false

# ── Optional AI Module (disabled by default) ──────────────────────────────
# Only enable for offline/enterprise environments without editor AI access.
# BOLLARD_AI_ENABLED=false
# BOLLARD_AI_PROVIDER=anthropic          # 'anthropic' | 'nvidia_nim'
# BOLLARD_ANTHROPIC_API_KEY=
# BOLLARD_NVIDIA_NIM_API_KEY=
# BOLLARD_NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
